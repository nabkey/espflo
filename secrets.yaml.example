# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is git-ignored so your credentials never get committed.

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# Used for the fallback hotspot the device exposes if Wi-Fi fails.
fallback_ap_password: "changeme123"

# Generate with:  openssl rand -base64 32   (or the ESPHome dashboard)
api_encryption_key: "REPLACE_WITH_32_BYTE_BASE64_KEY"

ota_password: "REPLACE_WITH_A_PASSWORD"
