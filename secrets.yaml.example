# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is git-ignored so your credentials never get committed.
#
# These are the only secrets pump.yaml needs. If you run this inside the
# Home Assistant ESPHome add-on, its shared secrets.yaml almost certainly
# already defines wifi_ssid / wifi_password — in that case you don't need
# this file at all; pump.yaml just reuses the existing keys.

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"
